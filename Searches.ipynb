import ipywidgets as widgets
from IPython.display import display
import math


class MyStack:
    def __init__(self, capacity=10000):
        self.arr = [None] * capacity 
        self.top = -1
        
    def push(self, item):
        self.top += 1
        self.arr[self.top] = item
        
    def pop(self):
        if self.is_empty(): return None
        item = self.arr[self.top]
        self.top -= 1
        return item
        
    def is_empty(self):
        return self.top == -1

class MyQueue:
    def __init__(self, capacity=10000):
        self.arr = [None] * capacity 
        self.head = 0
        self.tail = 0
        
    def push(self, item):
        self.arr[self.tail] = item
        self.tail += 1
        
    def pop(self):
        if self.is_empty(): return None
        item = self.arr[self.head]
        self.head += 1
        return item
        
    def is_empty(self):
        return self.head == self.tail

class MyPriorityQueue:
    def __init__(self, capacity=10000):
        self.arr = [None] * capacity 
        self.size = 0
        
    def push(self, priority, tie_breaker, item):
        self.arr[self.size] = (priority, tie_breaker, item)
        self._bubble_up(self.size)
        self.size += 1
        
    def pop(self):
        if self.size == 0: return None
        min_val = self.arr[0]
        self.size -= 1
        self.arr[0] = self.arr[self.size]
        self.arr[self.size] = None
        self._bubble_down(0)
        return min_val
        
    def _bubble_up(self, idx):
        while idx > 0:
            parent = (idx - 1) // 2
            curr = self.arr[idx]
            par = self.arr[parent]
            if curr[0] < par[0] or (curr[0] == par[0] and curr[1] < par[1]):
                self.arr[idx], self.arr[parent] = self.arr[parent], self.arr[idx]
                idx = parent
            else:
                break
                
    def _bubble_down(self, idx):
        while True:
            left = 2 * idx + 1
            right = 2 * idx + 2
            smallest = idx
            
            if left < self.size:
                curr = self.arr[smallest]
                l_val = self.arr[left]
                if l_val[0] < curr[0] or (l_val[0] == curr[0] and l_val[1] < curr[1]):
                    smallest = left
                    
            if right < self.size:
                curr = self.arr[smallest]
                r_val = self.arr[right]
                if r_val[0] < curr[0] or (r_val[0] == curr[0] and r_val[1] < curr[1]):
                    smallest = right
                    
            if smallest != idx:
                self.arr[idx], self.arr[smallest] = self.arr[smallest], self.arr[idx]
                idx = smallest
            else:
                break
                
    def is_empty(self):
        return self.size == 0

def create_2d_array(rows, cols, default_val):
    arr = [None] * rows
    for i in range(rows):
        arr[i] = [default_val] * cols
    return arr

# ==========================================
# GUI AND MAIN APPLICATION (Jupyter / ipywidgets)
# ==========================================

class PathfinderJupyterGUI:
    def __init__(self, rows=20, cols=20):
        self.ROWS = rows
        self.COLS = cols
        
        # 0 -> Free, 1 -> Blocked
        self.grid = create_2d_array(self.ROWS, self.COLS, 0)
        # Parallel array for costs. Default every free cell to 1.
        self.costs = create_2d_array(self.ROWS, self.COLS, 1) 
        
        self.buttons = create_2d_array(self.ROWS, self.COLS, None)
        
        self.start_cell = None
        self.goal_cell = None
        
        self.setup_ui()
        self.draw_grid()

    def setup_ui(self):
        # Updated Cost modes to reflect the new purple theme
        self.mode = widgets.RadioButtons(
            options=[
                'Toggle Blocked', 
                'Set Start', 
                'Set Goal',
                'Set Cost: 1 (Light Purple)',
                'Set Cost: 5 (Med Purple)',
                'Set Cost: 9 (Dark Purple)'
            ],
            value='Toggle Blocked',
            description='Click Mode:'
        )
        
        self.algo = widgets.RadioButtons(
            options=['BFS', 'DFS', 'UCS', 'A*_Manhattan', 'A*_Euclidean'],
            value='BFS',
            description='Algorithm:'
        )
        
        self.run_btn = widgets.Button(description='Run Algorithm', button_style='success')
        self.run_btn.on_click(self.run_algorithm)
        
        self.clear_btn = widgets.Button(description='Clear Path/Visited')
        self.clear_btn.on_click(self.clear_visualization)
        
        self.reset_btn = widgets.Button(description='Reset Entire Grid', button_style='danger')
        self.reset_btn.on_click(self.reset_grid)
        
        self.status_label = widgets.HTML(value='<b style="color:blue">Status: Ready</b>')
        self.output = widgets.Output()
        
        controls = widgets.VBox([
            self.mode, 
            widgets.HTML("<hr>"), 
            self.algo, 
            widgets.HTML("<hr>"), 
            self.run_btn, 
            self.clear_btn, 
            self.reset_btn, 
            widgets.HTML("<br>"),
            self.status_label,
            self.output
        ])
        
        total_cells = self.ROWS * self.COLS
        all_buttons_flat = [None] * total_cells
        
        idx = 0
        for r in range(self.ROWS):
            for c in range(self.COLS):
                btn = widgets.Button(layout=widgets.Layout(
                    width='30px', height='30px', 
                    min_width='30px', min_height='30px', 
                    margin='0px', padding='0px'
                ))
                
                def make_callback(row, col):
                    def callback(b):
                        self.process_mouse(row, col)
                    return callback
                    
                btn.on_click(make_callback(r, c))
                self.buttons[r][c] = btn
                all_buttons_flat[idx] = btn
                idx += 1
                
        grid_layout = widgets.Layout(
            grid_template_columns=f'repeat({self.COLS}, 32px)',
            grid_template_rows=f'repeat({self.ROWS}, 32px)',
            grid_gap='1px'
        )
        
        self.grid_ui = widgets.GridBox(children=all_buttons_flat, layout=grid_layout)
        controls.layout.margin = '0px 30px 0px 0px'
        
        self.ui = widgets.HBox([controls, self.grid_ui])

    def draw_grid(self):
        for r in range(self.ROWS):
            for c in range(self.COLS):
                if self.grid[r][c] == 1:
                    color = "black"
                else:
                    # Color the cell based on its cost using the purple theme
                    cost = self.costs[r][c]
                    if cost == 1: color = "#f3e5f5"     # Light Purple
                    elif cost == 5: color = "#ce93d8"   # Medium Purple
                    elif cost == 9: color = "#8e24aa"   # Dark Purple
                    else: color = "#f3e5f5"
                    
                if self.start_cell == (r, c):
                    color = "green"
                elif self.goal_cell == (r, c):
                    color = "red"
                self.buttons[r][c].style.button_color = color

    def color_cell(self, r, c, color):
        if (r, c) == self.start_cell or (r, c) == self.goal_cell:
            return 
        self.buttons[r][c].style.button_color = color

    def process_mouse(self, r, c):
        mode = self.mode.value
        if mode == "Toggle Blocked":
            if (r, c) != self.start_cell and (r, c) != self.goal_cell:
                self.grid[r][c] = 1 if self.grid[r][c] == 0 else 0
        elif mode == "Set Start":
            if self.grid[r][c] != 1: self.start_cell = (r, c)
        elif mode == "Set Goal":
            if self.grid[r][c] != 1: self.goal_cell = (r, c)
        elif mode == "Set Cost: 1 (Light Purple)":
            if self.grid[r][c] != 1: self.costs[r][c] = 1
        elif mode == "Set Cost: 5 (Med Purple)":
            if self.grid[r][c] != 1: self.costs[r][c] = 5
        elif mode == "Set Cost: 9 (Dark Purple)":
            if self.grid[r][c] != 1: self.costs[r][c] = 9
            
        self.draw_grid()

    def clear_visualization(self, b=None):
        self.status_label.value = '<b style="color:blue">Status: Ready</b>'
        self.output.clear_output()
        self.draw_grid()

    def reset_grid(self, b=None):
        self.grid = create_2d_array(self.ROWS, self.COLS, 0)
        self.costs = create_2d_array(self.ROWS, self.COLS, 1) # Reset costs to 1
        self.start_cell = None
        self.goal_cell = None
        self.clear_visualization()

    def reconstruct_path(self, parent_map, final_cost=None):
        if not self.goal_cell or parent_map[self.goal_cell[0]][self.goal_cell[1]] is None:
            self.status_label.value = '<b style="color:red">Failure: Goal unreachable!</b>'
            return
            
        path_stack = MyStack()
        curr = self.goal_cell
        while curr != self.start_cell:
            path_stack.push(curr)
            curr = parent_map[curr[0]][curr[1]]
        path_stack.push(self.start_cell)
        
        with self.output:
            print(f"--- Final Path ({self.algo.value}) ---")
            while not path_stack.is_empty():
                node = path_stack.pop()
                print(f"{node[0]} {node[1]}") 
                self.color_cell(node[0], node[1], "#008cff") # Bright blue for visibility
            
        msg = '<b style="color:green">Goal Reached!</b>'
        if final_cost is not None: msg += f'<br><b style="color:green">Total Cost: {final_cost}</b>'
        self.status_label.value = msg

    def get_neighbors(self, r, c):
        directions = [(-1, 0), (1, 0), (0, -1), (0, 1)]
        idx = 0
        arr = [None] * 4
        for dr, dc in directions:
            nr, nc = r + dr, c + dc
            if 0 <= nr < self.ROWS and 0 <= nc < self.COLS:
                if self.grid[nr][nc] == 0:
                    arr[idx] = (nr, nc)
                    idx += 1
        res = [None] * idx
        for i in range(idx): res[i] = arr[i]
        return res

    def run_algorithm(self, b=None):
        if not self.start_cell or not self.goal_cell:
            self.status_label.value = '<b style="color:red">Error: Set Start and Goal!</b>'
            return
        
        self.clear_visualization()
        self.status_label.value = '<b style="color:orange">Running...</b>'
        algo = self.algo.value
        
        if algo == "BFS": self.run_bfs()
        elif algo == "DFS": self.run_dfs()
        elif algo == "UCS": self.run_ucs()
        elif algo == "A*_Manhattan": self.run_astar("manhattan")
        elif algo == "A*_Euclidean": self.run_astar("euclidean")

    # ================= Algorithms =================

    def run_bfs(self):
        q = MyQueue()
        visited = create_2d_array(self.ROWS, self.COLS, False)
        parent = create_2d_array(self.ROWS, self.COLS, None)
        
        q.push(self.start_cell)
        visited[self.start_cell[0]][self.start_cell[1]] = True
        
        while not q.is_empty():
            curr = q.pop()
            r, c = curr
            
            if curr == self.goal_cell:
                self.reconstruct_path(parent)
                return
                
            self.color_cell(r, c, "#ffe100") # Yellow visited
            
            neighbors = self.get_neighbors(r, c)
            for i in range(len(neighbors)):
                nr, nc = neighbors[i]
                if not visited[nr][nc]:
                    visited[nr][nc] = True
                    parent[nr][nc] = curr
                    q.push((nr, nc))
                    
        self.status_label.value = '<b style="color:red">Failure: Goal unreachable!</b>'

    def run_dfs(self):
        stack = MyStack()
        visited = create_2d_array(self.ROWS, self.COLS, False)
        parent = create_2d_array(self.ROWS, self.COLS, None)
        
        stack.push((self.start_cell, None))
        
        while not stack.is_empty():
            curr_data = stack.pop()
            curr = curr_data[0]
            p = curr_data[1]
            r, c = curr
            
            if not visited[r][c]:
                visited[r][c] = True
                parent[r][c] = p
                self.color_cell(r, c, "#ffe100")
                
                if curr == self.goal_cell:
                    self.reconstruct_path(parent)
                    return
                
                neighbors = self.get_neighbors(r, c)
                for i in range(len(neighbors)):
                    nr, nc = neighbors[i]
                    if not visited[nr][nc]:
                        stack.push(((nr, nc), curr))
                        
        self.status_label.value = '<b style="color:red">Failure: Goal unreachable!</b>'

    def run_ucs(self):
        pq = MyPriorityQueue()
        g_costs = create_2d_array(self.ROWS, self.COLS, float('inf'))
        parent = create_2d_array(self.ROWS, self.COLS, None)
        
        pq.push(0, 0, self.start_cell)
        g_costs[self.start_cell[0]][self.start_cell[1]] = 0
        
        while not pq.is_empty():
            node_data = pq.pop()
            curr_g, _, curr = node_data
            r, c = curr
            
            if curr == self.goal_cell:
                self.reconstruct_path(parent, final_cost=curr_g)
                return
                
            if curr_g > g_costs[r][c]:
                continue
                
            self.color_cell(r, c, "#ffe100")
            
            neighbors = self.get_neighbors(r, c)
            for i in range(len(neighbors)):
                nr, nc = neighbors[i]
                # UCS ADDS THE CELL COST INSTEAD OF 1
                new_g = curr_g + self.costs[nr][nc]
                
                if new_g < g_costs[nr][nc]:
                    g_costs[nr][nc] = new_g
                    parent[nr][nc] = curr
                    pq.push(new_g, new_g, (nr, nc))
                    
        self.status_label.value = '<b style="color:red">Failure: Goal unreachable!</b>'

    def run_astar(self, heuristic_type):
        pq = MyPriorityQueue()
        g_costs = create_2d_array(self.ROWS, self.COLS, float('inf'))
        parent = create_2d_array(self.ROWS, self.COLS, None)
        
        start_r, start_c = self.start_cell
        gr, gc = self.goal_cell
        
        def get_h(r, c):
            if heuristic_type == "manhattan":
                return abs(r - gr) + abs(c - gc)
            else:
                return math.sqrt((r - gr)**2 + (c - gc)**2)

        start_h = get_h(start_r, start_c)
        g_costs[start_r][start_c] = 0
        
        pq.push(start_h, 0, self.start_cell)
        
        while not pq.is_empty():
            node_data = pq.pop()
            curr_f, curr_g, curr = node_data
            r, c = curr
            
            if curr == self.goal_cell:
                self.reconstruct_path(parent, final_cost=curr_g)
                return
                
            if curr_g > g_costs[r][c]:
                continue
                
            self.color_cell(r, c, "#ffe100")
            
            neighbors = self.get_neighbors(r, c)
            for i in range(len(neighbors)):
                nr, nc = neighbors[i]
                # A* ADDS THE CELL COST INSTEAD OF 1
                new_g = curr_g + self.costs[nr][nc]
                
                if new_g < g_costs[nr][nc]:
                    g_costs[nr][nc] = new_g
                    parent[nr][nc] = curr
                    f_val = new_g + get_h(nr, nc)
                    pq.push(f_val, new_g, (nr, nc))

        self.status_label.value = '<b style="color:red">Failure: Goal unreachable!</b>'


app = PathfinderJupyterGUI(rows=20, cols=20)
display(app.ui)
